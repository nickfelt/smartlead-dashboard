# Smartlead
SMARTLEAD_API_KEY=           # Your master Smartlead API key

# Supabase
SUPABASE_URL=                # Supabase project URL
SUPABASE_ANON_KEY=           # Supabase anon/public key
SUPABASE_SERVICE_KEY=        # Supabase service role key (server-side only)

# Stripe
STRIPE_SECRET_KEY=           # Stripe secret key
STRIPE_PUBLISHABLE_KEY=      # Stripe publishable key
STRIPE_WEBHOOK_SECRET=       # Stripe webhook signing secret

# Security
ENCRYPTION_KEY=              # AES key for encrypting stored API keys (client AI keys, Smartlead client keys)

# Frontend (exposed to client via Vite)
VITE_SUPABASE_URL=           # Same as SUPABASE_URL (exposed to frontend)
VITE_SUPABASE_ANON_KEY=      # Same as SUPABASE_ANON_KEY (exposed to frontend)
VITE_STRIPE_PUBLISHABLE_KEY= # Same as STRIPE_PUBLISHABLE_KEY (exposed to frontend)
VITE_API_URL=                # Backend API URL (e.g., https://app.feltmarketing.com/api)

# Development
USE_MOCK=true                # Set to "true" to use mock data for all external services (Smartlead, Stripe, Supabase, AI). Set to "false" when ready to go live with real keys.
