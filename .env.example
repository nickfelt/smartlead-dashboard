# ─── Smartlead ────────────────────────────────────────────────────────────────
SMARTLEAD_API_KEY=           # Your master Smartlead API key

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=                # Supabase project URL (https://xxxx.supabase.co)
SUPABASE_ANON_KEY=           # Supabase anon/public key
SUPABASE_SERVICE_KEY=        # Supabase service role key (server-side only, never expose)

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=           # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_PUBLISHABLE_KEY=      # Stripe publishable key (pk_live_... or pk_test_...)
STRIPE_WEBHOOK_SECRET=       # Stripe webhook signing secret (whsec_...)

# ─── Security ─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=              # AES-256 Fernet key for encrypting stored API keys.
                             # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.feltmarketing.com   # Allowed CORS origin(s), comma-separated

# ─── Vite (exposed to browser) ────────────────────────────────────────────────
VITE_SUPABASE_URL=           # Same as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=      # Same as SUPABASE_ANON_KEY (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY= # Same as STRIPE_PUBLISHABLE_KEY (safe to expose)
VITE_API_URL=                # API base URL, e.g. https://app.feltmarketing.com/api

# ─── Development ──────────────────────────────────────────────────────────────
USE_MOCK=true                # "true"  → mock all external services (Smartlead, Stripe, Supabase, AI)
                             # "false" → use real keys above (production mode)
